# Bitmod Environment Configuration
# https://bitmod.io — Modular AI Data Infrastructure

# ============================================================================
# DATABASE BACKEND
# ============================================================================
# Options: sqlite (default), postgresql, mysql, mongodb
BITMOD_DB_BACKEND=sqlite

# SQLite (default — works everywhere, no server needed)
# NOTE: For deployments with >50,000 embeddings, use PostgreSQL instead of SQLite.
# SQLite stores embeddings as BLOBs which degrades performance at scale.
# The VectorIndex mitigates search latency but storage bloat remains.
BITMOD_SQLITE_PATH=bitmod.db

# PostgreSQL (production — requires: pip install bitmod[postgresql])
# BITMOD_DB_BACKEND=postgresql
# DATABASE_URL=postgresql://bitmod:password@localhost:5432/bitmod

# MySQL/MariaDB (requires: pip install bitmod[mysql])
# BITMOD_DB_BACKEND=mysql
# BITMOD_MYSQL_URL=mysql+pymysql://bitmod:password@localhost:3306/bitmod

# MongoDB (requires: pip install bitmod[mongodb])
# BITMOD_DB_BACKEND=mongodb
# BITMOD_MONGODB_URL=mongodb://localhost:27017
# BITMOD_MONGODB_DB=bitmod

# ============================================================================
# LLM PROVIDER (works with any OpenAI-compatible API)
# ============================================================================
# Just set these 3 values. Works with Ollama, OpenAI, Groq, Together,
# Mistral, Fireworks, vLLM, LM Studio, Jan.ai, OpenRouter, and 200+ more.
BITMOD_LLM_URL=http://localhost:11434/v1
BITMOD_LLM_API_KEY=
BITMOD_LLM_MODEL=llama3.2

# Examples:
#   Ollama:      BITMOD_LLM_URL=http://localhost:11434/v1   BITMOD_LLM_MODEL=llama3.2
#   Groq:        BITMOD_LLM_URL=https://api.groq.com/openai/v1
#   Together:    BITMOD_LLM_URL=https://api.together.xyz/v1
#   Fireworks:   BITMOD_LLM_URL=https://api.fireworks.ai/inference/v1
#   OpenRouter:  BITMOD_LLM_URL=https://openrouter.ai/api/v1
#   vLLM:        BITMOD_LLM_URL=http://localhost:8000/v1
#   LM Studio:   BITMOD_LLM_URL=http://localhost:1234/v1
#   OpenAI:      BITMOD_LLM_URL=https://api.openai.com/v1
#   Mistral:     BITMOD_LLM_URL=https://api.mistral.ai/v1

# --- Provider-specific (optional, overrides universal config) ---
# Only needed if you want provider-specific features like Anthropic prompt caching.
# BITMOD_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
#
# BITMOD_LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
#
# BITMOD_LLM_PROVIDER=gemini
# GEMINI_API_KEY=
#
# BITMOD_LLM_PROVIDER=xai
# XAI_API_KEY=
#
# BITMOD_LLM_PROVIDER=bedrock
# AWS_REGION=us-east-1
#
# BITMOD_LLM_PROVIDER=azure_openai
# AZURE_OPENAI_ENDPOINT=https://myresource.openai.azure.com/
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# --- Fallback LLM (optional) ---
# BITMOD_LLM_FALLBACK=ollama
# BITMOD_LLM_FALLBACK_MODEL=llama3.2

# ============================================================================
# EMBEDDING PROVIDERS
# ============================================================================
# Options: local (default), openai, cohere, ollama
BITMOD_EMBEDDING_PROVIDER=local
BITMOD_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
BITMOD_EMBEDDING_DEVICE=cpu
BITMOD_EMBEDDING_DIMENSIONS=384
# Common dimensions: 384 (MiniLM), 768 (BERT/e5), 1024 (Cohere), 1536 (OpenAI), 3072 (OpenAI large)

# OpenAI embeddings
# BITMOD_EMBEDDING_PROVIDER=openai
# BITMOD_EMBEDDING_MODEL=text-embedding-3-small

# Cohere embeddings (requires: pip install bitmod[embeddings-cohere])
# BITMOD_EMBEDDING_PROVIDER=cohere
# COHERE_API_KEY=
# BITMOD_EMBEDDING_MODEL=embed-v4.0

# Ollama embeddings (uses same server as LLM)
# BITMOD_EMBEDDING_PROVIDER=ollama
# BITMOD_EMBEDDING_MODEL=nomic-embed-text

# ============================================================================
# VECTOR STORE (optional — leave empty to use database backend's built-in)
# ============================================================================
# Options: (empty), chroma, qdrant, pinecone
BITMOD_VECTOR_STORE=

# ChromaDB (embedded, great for local dev — requires: pip install bitmod[chroma])
# BITMOD_VECTOR_STORE=chroma
# BITMOD_CHROMA_COLLECTION=bitmod
# BITMOD_CHROMA_PATH=./chroma_data

# Qdrant (requires: pip install bitmod[qdrant])
# BITMOD_VECTOR_STORE=qdrant
# BITMOD_QDRANT_URL=http://localhost:6333
# BITMOD_QDRANT_API_KEY=
# BITMOD_QDRANT_COLLECTION=bitmod

# Pinecone (requires: pip install bitmod[pinecone])
# BITMOD_VECTOR_STORE=pinecone
# BITMOD_PINECONE_API_KEY=
# BITMOD_PINECONE_INDEX=bitmod
# BITMOD_PINECONE_NAMESPACE=default

# ============================================================================
# REDIS (optional — for rate limiting, sessions)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
# Password for Redis authentication. When using Docker Compose, Redis requires
# this password via --requirepass.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# REDIS_PASSWORD=

# ============================================================================
# GATEWAY / SERVICES
# ============================================================================
GATEWAY_PORT=8000
CHAT_PORT=8001
FRONTEND_PORT=3000
CORS_ORIGINS=https://bitmod.io,https://app.bitmod.io
CHAT_SERVICE_URL=http://chat:8001
NEXT_PUBLIC_API_URL=https://api.bitmod.io

# ============================================================================
# DOCKER / POSTGRESQL
# ============================================================================
# Generate password with: python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_USER=bitmod
# POSTGRES_PASSWORD=
POSTGRES_DB=bitmod
POSTGRES_PORT=5432
# DATABASE_URL=postgresql://bitmod:<password>@bitmod-postgres:5432/bitmod

# ============================================================================
# MESSAGING PLATFORMS (for MessagingBridge integration)
# ============================================================================
# All messaging adapters use httpx (already a core dependency).

# --- Telegram ---
# TELEGRAM_BOT_TOKEN=

# --- Discord ---
# DISCORD_BOT_TOKEN=

# --- Slack ---
# SLACK_BOT_TOKEN=

# --- WhatsApp (Meta Cloud API) ---
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# --- Matrix ---
# MATRIX_HOMESERVER=https://matrix.org
# MATRIX_ACCESS_TOKEN=

# ============================================================================
# INTERNAL SERVICE AUTH
# ============================================================================
# Shared secret between gateway and chat service. Required when running via
# Docker Compose (gateway IP is not localhost from chat's perspective).
# If not set, the chat service only accepts requests from localhost.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# BITMOD_INTERNAL_TOKEN=

# ============================================================================
# AUTH
# ============================================================================
# BITMOD_AUTH_ENABLED=true
# BITMOD_JWT_SECRET=<generate with: python -c "import secrets; print(secrets.token_hex(32))">
# BITMOD_API_KEYS=key1,key2
# BITMOD_JWT_EXPIRY_SECONDS=3600

# JWT Algorithm: HS256 (default, symmetric) or RS256 (asymmetric, recommended for production)
# BITMOD_JWT_ALGORITHM=HS256

# RS256 key files (optional — if not set, keys are auto-generated in BITMOD_DATA_DIR)
# Generate manually: openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
#                    openssl rsa -pubout -in private.pem -out public.pem
# BITMOD_JWT_PRIVATE_KEY_FILE=/path/to/private.pem
# BITMOD_JWT_PUBLIC_KEY_FILE=/path/to/public.pem

# Data directory for auto-generated keys and other persistent state
# Defaults to ~/.bitmod/
# BITMOD_DATA_DIR=/var/lib/bitmod

# ============================================================================
# PROJECT KNOWLEDGE SECURITY
# ============================================================================
# Comma-separated list of directories that can be registered as projects.
# Defaults to the current user's home directory if not set.
# BITMOD_PROJECT_ALLOWED_DIRS=/home/deploy/projects,/opt/data

# ============================================================================
# ENCRYPTION AT REST (optional)
# ============================================================================
# Envelope encryption for cached answers and backup journal entries.
# Provide a 64-character hex string (32 bytes) as the key encryption key (KEK).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# BITMOD_ENCRYPTION_KEY=
# Or point to a file containing the hex key:
# BITMOD_ENCRYPTION_KEY_FILE=/path/to/kek.key
#
# When neither is set, data is stored in plaintext. For additional protection,
# use OS-level encryption (LUKS, FileVault, BitLocker) or PostgreSQL with
# pgcrypto / Transparent Data Encryption.

# ============================================================================
# STORAGE LIMITS
# ============================================================================
# Max characters for cached answer text (truncated if exceeded)
# BITMOD_MAX_ANSWER_LENGTH=100000
# Max atomic facts before LRU eviction (lowest serve_count evicted first)
# BITMOD_MAX_ATOMIC_FACTS=500000
# Max similarity links before LRU eviction (lowest strength evicted first)
# BITMOD_MAX_SIMILARITY_LINKS=1000000
# Audit event retention in days (older events are purged)
# BITMOD_AUDIT_RETENTION_DAYS=90
# Max documents per namespace (429 returned when limit reached)
# BITMOD_MAX_DOCUMENTS=50000
